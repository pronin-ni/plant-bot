TELEGRAM_BOT_TOKEN=your_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
TELEGRAM_BOT_ENABLED=true
APP_FEATURE_MINI_APP_ENABLED=true
APP_FEATURE_PWA_ENABLED=true
SPRING_DATASOURCE_URL=jdbc:sqlite:./data/plantbot.db?busy_timeout=10000&journal_mode=WAL&synchronous=NORMAL
DB_POOL_MAX_SIZE=1
DB_POOL_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=30000
BOT_UPDATE_THREADS=4
BOT_LIST_CARD_CACHE_MAX_ENTRIES=1000
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL_PLANT=
OPENROUTER_MODEL_PHOTO_IDENTIFY=google/gemini-flash-1.5
OPENROUTER_MODEL_PHOTO_DIAGNOSE=google/gemini-1.5-pro
OPENROUTER_MODEL_CHAT=
OPENROUTER_CARE_CACHE_TTL_MINUTES=10080
OPENROUTER_WATERING_CACHE_TTL_MINUTES=720
OPENROUTER_CHAT_CACHE_TTL_MINUTES=10080
OPENROUTER_CACHE_MAX_ENTRIES=5000
OPENROUTER_CHAT_FALLBACK_ENABLED=false
OPENWEATHER_API_KEY=your_openweather_key_here
OPENWEATHER_CACHE_MAX_ENTRIES=500
OPENWEATHER_RAIN_MAX_KEYS=500
PERENUAL_API_KEY=your_perenual_key_here
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
WEB_CORS_ALLOWED_ORIGINS=*
APP_PUBLIC_BASE_URL=http://localhost:8080
PWA_VITE_API_BASE_URL=
PWA_VITE_TELEGRAM_BOT_USERNAME=your_bot_username_here
PWA_VITE_PWA_URL=http://localhost:8080/pwa/
PWA_VITE_BASE_PATH=/pwa/
APP_SECURITY_JWT_SECRET=change-me-change-me-change-me-change-me
APP_SECURITY_JWT_TTL_SECONDS=2592000
APP_SECURITY_JWT_ISSUER=plant-care
APP_BACKUP_ENABLED=true
APP_BACKUP_CRON=0 10 3 * * *
APP_BACKUP_ZONE=Europe/Moscow
APP_BACKUP_PATH=./data/backups
APP_BACKUP_RETENTION_DAYS=7
APP_BACKUP_FILE_PREFIX=plantbot-backup
APP_ADMIN_TELEGRAM_ID=0
APP_ADMIN_RATE_LIMIT_MAX_REQUESTS=120
APP_ADMIN_RATE_LIMIT_WINDOW_SECONDS=60
WEB_PUSH_ENABLED=false
